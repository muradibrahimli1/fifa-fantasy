# --- Telegram delivery (required for the 24/7 bot) -------------------------
# 1. In Telegram, message @BotFather → /newbot → copy the token here.
TELEGRAM_BOT_TOKEN=

# 2. Message your new bot once, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id": ...}.
TELEGRAM_CHAT_ID=

# --- Your squad for the scheduled analysis ---------------------------------
# Comma-separated player ids. Copy this from the Advisor page (it shows the
# exact value for your saved squad).
MY_SQUAD_IDS=

# --- Cron security ----------------------------------------------------------
# Any random string. Vercel automatically sends it as a Bearer token to the
# cron route; requests without it are rejected.
CRON_SECRET=

# --- AI Coach (OpenAI) ------------------------------------------------------
# Get a key at https://platform.openai.com/api-keys. When set, the Advisor page
# and the 24/7 Telegram digest include a GPT-made decision (captain, transfers,
# chip, formation). Each generation is one paid API call.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o).
# OPENAI_MODEL=gpt-4o

# --- Optional ---------------------------------------------------------------
# How often (seconds) to revalidate the FIFA feed cache. Default 900 (15 min).
# FIFA_REVALIDATE_SECONDS=900
